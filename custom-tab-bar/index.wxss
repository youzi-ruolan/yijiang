.custom-tab-bar-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.icon-wrap {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -18rpx;
  min-width: 28rpx;
  height: 28rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #ff5c51;
  color: #fff;
  font-size: 16rpx;
  line-height: 28rpx;
  text-align: center;
  box-sizing: border-box;
}

.custom-tab-bar-wrapper .text {
  font-size: 20rpx;
}
