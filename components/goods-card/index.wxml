<view
  id="{{independentID}}"
  class="goods-card {{compact ? 'goods-card--compact' : ''}}"
  bind:tap="clickHandle"
  data-goods="{{ goods }}"
>
	<view class="goods-card__main {{compact ? 'goods-card__main--compact' : ''}}">
		<view class="goods-card__thumb {{compact ? 'goods-card__thumb--compact' : ''}}" bind:tap="clickThumbHandle">
			<t-image
			  wx:if="{{ !!goods.thumb }}"
			  t-class="goods-card__img {{compact ? 'goods-card__img--compact' : ''}}"
			  src="{{ goods.thumb }}"
			  mode="aspectFill"
			  lazy-load
			/>
		</view>
		<view class="goods-card__body {{compact ? 'goods-card__body--compact' : ''}}">
			<view class="goods-card__upper">
				<view wx:if="{{ goods.title }}" class="goods-card__title {{compact ? 'goods-card__title--compact' : ''}}">
					{{ goods.title }}
				</view>
				<view wx:if="{{ goods.tags && !!goods.tags.length }}" class="goods-card__tags {{compact ? 'goods-card__tags--compact' : ''}}">
					<view
					  wx:for="{{ goods.tags }}"
					  wx:key="index"
					  wx:for-item="tag"
					  class="goods-card__tag {{compact ? 'goods-card__tag--compact' : ''}}"
					  data-index="{{index}}"
					>
						{{tag}}
					</view>
				</view>
			</view>
			<view class="goods-card__down {{compact ? 'goods-card__down--compact' : ''}}">
				<price
				  wx:if="{{ goods.price }}"
				  wr-class="spec-for-price {{compact ? 'spec-for-price--compact' : ''}}"
				  symbol-class="spec-for-symbol {{compact ? 'spec-for-symbol--compact' : ''}}"
				  symbol="{{currency}}"
				  price="{{goods.price}}"
				/>
				<price
				  wx:if="{{!compact && goods.originPrice && isValidityLinePrice }}"
				  wr-class="goods-card__origin-price"
				  symbol="{{currency}}"
				  price="{{goods.originPrice}}"
				  type="delthrough"
				/>
				<t-icon
				  class="goods-card__add-cart {{compact ? 'goods-card__add-cart--compact' : ''}}"
				  prefix="wr"
				  name="cartAdd"
				  id="{{independentID}}-cart"
				  data-id="{{independentID}}"
				  catchtap="addCartHandle"
				  size="48rpx"
				  color="#FA550F"
				/>
			</view>
		</view>
	</view>
</view>
