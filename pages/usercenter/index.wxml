<t-user-center-card
  wx:if="{{currAuthStep === 3}}"
  userInfo="{{userInfo}}"
  isPhoneHide="{{true}}"
  name-class="custom-name-class"
  phone-class="custom-phone-class"
  avatar-class="customer-avatar-class"
  currAuthStep="{{currAuthStep}}"
  profileIncomplete="{{profileIncomplete}}"
  bind:loginByAvatar="loginByAvatar"
  bind:gotoUserEditPage="gotoUserEditPage"
  bind:requestProfileAuth="authorizeWechatProfile"
/>
<view class="content-wrapper" wx:if="{{currAuthStep === 3}}">
  <view class="order-group-wrapper">
    <t-order-group orderTagInfos="{{orderTagInfos}}" bind:onClickTop="jumpAllOrder" bind:onClickItem="jumpNav" />
  </view>
  <view wx:for="{{menuData}}" wx:key="item" class="cell-box">
    <t-cell-group>
      <t-cell
        wx:for="{{item}}"
        wx:for-item="xitem"
        wx:for-index="xindex"
        wx:key="xindex"
        title="{{xitem.title}}"
        arrow="{{!xitem.icon}}"
        note="{{xitem.tit}}"
        data-type="{{xitem.type}}"
        bordered="{{false}}"
        bind:click="onClickCell"
        t-class="t-cell-padding"
        t-class-note="order-group-note"
        t-class-left="order-group__left"
      >
        <t-icon name="{{xitem.icon}}" size="48rpx" slot="note" />
      </t-cell>
    </t-cell-group>
  </view>
</view>
<view class="guest-login" wx:else>
  <view class="guest-login__title">请登录</view>
  <view class="guest-login__logo">艺</view>
  <button class="guest-login__button" bindtap="loginByAvatar">手机号快捷登录</button>
</view>
<t-popup visible="{{showProfileSetup}}" placement="bottom" bind:visible-change="closeProfileSetup">
  <view class="profile-setup">
    <view class="profile-setup__handle"></view>
    <view class="profile-setup__title">完善微信资料</view>
    <view class="profile-setup__desc">选择头像并填写昵称，保存后立即在个人中心展示</view>
    <button class="profile-setup__avatar-btn" open-type="chooseAvatar" bind:chooseavatar="onProfileChooseAvatar">
      <image
        class="profile-setup__avatar"
        src="{{profileDraft.avatarUrl || userInfo.avatarUrl || 'https://tdesign.gtimg.com/miniprogram/template/retail/usercenter/icon-user-center-avatar@2x.png'}}"
        mode="aspectFill"
      />
      <view class="profile-setup__avatar-tip">点击选择微信头像</view>
    </button>
    <view class="profile-setup__field">
      <view class="profile-setup__label">微信昵称</view>
      <input
        class="profile-setup__input"
        type="nickname"
        placeholder="点击输入或选择微信昵称"
        value="{{profileDraft.nickName}}"
        bindinput="onProfileNicknameInput"
        bindblur="onProfileNicknameInput"
      />
    </view>
    <button class="profile-setup__save" bindtap="onSaveProfileSetup">保存资料</button>
    <button class="profile-setup__cancel" bindtap="closeProfileSetup">稍后再说</button>
  </view>
</t-popup>
<t-popup visible="{{showLoginAuth}}" placement="bottom" bind:visible-change="closeLoginAuth">
  <view class="login-auth">
    <view class="login-auth__handle"></view>
    <view class="login-auth__top">
      <view class="login-auth__brand">
        <view class="login-auth__logo">艺</view>
        <view>
          <view class="login-auth__brand-name">艺匠调色</view>
          <view class="login-auth__brand-desc">微信安全授权</view>
        </view>
      </view>
      <view class="login-auth__close" bindtap="closeLoginAuth">
        <t-icon name="close" size="34rpx" color="#8a8a8a" />
      </view>
    </view>
    <view class="login-auth__title">授权手机号快捷登录</view>
    <view class="login-auth__desc">用于同步订单状态、售后联系与账号安全验证</view>
    <button
      class="login-auth__phone-btn"
      open-type="getPhoneNumber"
      bindgetphonenumber="onLoginGetPhoneNumber"
      loading="{{loginAuthLoading}}"
    >
      授权手机号快捷登录
    </button>
    <button class="login-auth__deny-btn" bindtap="closeLoginAuth">不允许</button>
  </view>
</t-popup>
<t-popup visible="{{showMakePhone}}" placement="bottom" bind:visible-change="closeMakePhone" data-index="2">
  <view class="popup-content">
    <view class="popup-title border-bottom-1px" wx:if="{{customerServiceInfo.serviceTimeDuration}}">
      服务时间: {{customerServiceInfo.serviceTimeDuration}}
    </view>
    <view class="popup-phone {{showKefu ? 'border-bottom-1px' : ''}}" bind:tap="call">电话客服</view>
    <button class="popup-phone border-bottom-1px online" open-type="contact" wx:if="{{showKefu}}">在线客服</button>
    <view class="popup-close" bind:tap="closeMakePhone">取消</view>
  </view>
</t-popup>
<t-toast id="t-toast" />
