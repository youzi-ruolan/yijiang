.user-center-card {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 480rpx;
  background-image: url('https://tdesign.gtimg.com/miniprogram/template/retail/template/user-center-bg-v1.png');
  background-size: cover;
  background-repeat: no-repeat;
  padding: 0 24rpx;
}
.user-center-card__header {
  margin-top: 192rpx;
  margin-bottom: 48rpx;
  min-height: 96rpx;
  line-height: 48rpx;
  display: flex;
  justify-content: flex-start;
  align-items: center;
  color: #333;
  position: relative;
  gap: 24rpx;
}

.user-center-card__avatar-wrap {
  position: relative;
  flex-shrink: 0;
}

.user-center-card__edit-badge {
  position: absolute;
  right: -4rpx;
  top: -4rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #fa4126;
  border: 3rpx solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 14rpx rgba(250, 65, 38, 0.28);
}

.user-center-card__profile {
  flex: 1;
  min-width: 0;
}

.user-center-card__profile-sub {
  margin-top: 6rpx;
  font-size: 24rpx;
  line-height: 34rpx;
  color: #888;
}

.user-center-card__profile-btn {
  margin: 14rpx 0 0;
  padding: 0 20rpx;
  height: 52rpx;
  line-height: 52rpx;
  border: 0;
  border-radius: 999rpx;
  background: rgba(250, 65, 38, 0.12);
  color: #fa4126;
  font-size: 22rpx;
  font-weight: 600;
}

.user-center-card__profile-btn::after {
  border: 0;
}
.user-center-card__header__avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  overflow: hidden;
  background: #f0f0f0;
}

.user-center-card__avatar-btn {
  width: 96rpx;
  height: 96rpx;
  padding: 0;
  margin: 0;
  border: 0;
  border-radius: 48rpx;
  background: transparent;
  line-height: 1;
}

.user-center-card__avatar-btn::after {
  border: 0;
}

.user-center-card__header__name {
  font-size: 36rpx;
  line-height: 48rpx;
  color: #333;
  font-weight: bold;
  margin-left: 0;
  margin-right: 0;
}
.user-center-card__header__transparent {
  position: absolute;
  left: 0;
  top: 0;
  background-color: transparent;
  height: 100%;
  width: 100%;
}
.user-center-card__icon {
  line-height: 96rpx;
}
