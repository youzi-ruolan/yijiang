<view class="user-center-card">
  <!-- 未登录的情况 -->
  <block wx:if="{{currAuthStep === AuthStepType.ONE}}">
    <view class="user-center-card__header">
      <button class="user-center-card__avatar-btn" bind:tap="loginByAvatar">
        <t-avatar image="{{userInfo.avatarUrl || defaultAvatarUrl}}" class="user-center-card__header__avatar" />
      </button>
      <view class="user-center-card__header__name">{{'请登录'}}</view>
    </view>
  </block>
  <!-- 已登录但未授权用户信息情况 -->
  <block wx:if="{{currAuthStep === AuthStepType.TWO}}">
    <view class="user-center-card__header">
      <t-avatar image="{{userInfo.avatarUrl || defaultAvatarUrl}}" class="user-center-card__header__avatar" />
      <view class="user-center-card__header__name">{{userInfo.nickName || '微信用户'}}</view>
      <!-- 需要授权用户信息，通过slot添加弹窗 -->
      <view class="user-center-card__header__transparent" wx:if="{{isNeedGetUserInfo}}">
        <slot name="getUserInfo" />
      </view>
      <!-- 不需要授权用户信息，仍然触发gotoUserEditPage事件 -->
      <view class="user-center-card__header__transparent" bind:tap="gotoUserEditPage" wx:else></view>
    </view>
  </block>
  <!-- 已登录且已经授权用户信息的情况 -->
  <block wx:if="{{currAuthStep === AuthStepType.THREE}}">
    <view class="user-center-card__header">
      <view
        class="user-center-card__avatar-wrap"
        bind:tap="{{profileIncomplete ? 'requestProfileAuth' : 'gotoUserEditPage'}}"
      >
        <t-avatar image="{{userInfo.avatarUrl || defaultAvatarUrl}}" class="user-center-card__header__avatar" />
        <view class="user-center-card__edit-badge">
          <t-icon name="{{profileIncomplete ? 'user' : 'edit-1'}}" size="22rpx" color="#ffffff" />
        </view>
      </view>
      <view class="user-center-card__profile">
        <view class="user-center-card__header__name">{{userInfo.nickName || '微信用户'}}</view>
        <view class="user-center-card__profile-sub" wx:if="{{userInfo.phoneNumber}}">{{userInfo.phoneNumber}}</view>
        <view wx:if="{{profileIncomplete}}" class="user-center-card__profile-hint" bind:tap="requestProfileAuth">
          点击头像，选择微信头像并填写昵称
        </view>
      </view>
    </view>
  </block>
</view>
