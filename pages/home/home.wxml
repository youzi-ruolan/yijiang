<view class="home-page">
  <view class="home-skeleton" wx:if="{{pageLoading}}">
    <view class="skeleton-block skeleton-header"></view>
    <view class="skeleton-block skeleton-search"></view>
    <view class="skeleton-block skeleton-banner"></view>
    <view class="skeleton-grid">
      <view class="skeleton-chip" wx:for="{{[1,2,3,4,5,6]}}" wx:key="*this"></view>
    </view>
    <view class="skeleton-grid cards">
      <view class="skeleton-card" wx:for="{{[1,2,3,4]}}" wx:key="*this"></view>
    </view>
  </view>

  <view class="home-shell" wx:else>
    <view class="search-bar" bindtap="navToSearchPage">
      <t-icon prefix="wr" name="search" size="34rpx" color="#c4c4c4" />
      <text class="search-text">新品火热发售中</text>
    </view>

    <view class="hero-wrap">
      <swiper
        class="hero-swiper"
        circular
        autoplay="{{autoplay}}"
        interval="{{interval}}"
        duration="{{duration}}"
        current="{{currentBannerIndex}}"
        bindchange="onBannerChange"
      >
        <block wx:for="{{bannerList}}" wx:key="id">
          <swiper-item>
            <view class="hero-slide" data-id="{{item.id}}" bindtap="onBannerAction">
              <image class="hero-image" src="{{item.image}}" mode="aspectFill" lazy-load />
              <view class="hero-overlay"></view>
              <view class="hero-content">
                <view class="hero-badge">{{item.badge}}</view>
                <view class="hero-title">{{item.title}}</view>
                <view class="hero-subtitle">{{item.subtitle}}</view>
                <view class="hero-description">{{item.description}}</view>
                <view class="hero-actions">
                  <view class="hero-cta">{{item.buttonText}}</view>
                  <view class="hero-secondary">Light tone · Curated assets · Instant access</view>
                </view>
              </view>
            </view>
          </swiper-item>
        </block>
      </swiper>

      <view class="hero-indicators" wx:if="{{bannerList.length > 1}}">
        <block wx:for="{{bannerList}}" wx:key="id">
          <view class="hero-indicator {{currentBannerIndex === index ? 'active' : ''}}"></view>
        </block>
      </view>
    </view>

    <view class="sticky-tabs">
      <scroll-view class="category-scroll" scroll-x show-scrollbar="false">
        <view class="category-track">
          <block wx:for="{{categoryList}}" wx:key="id">
            <view
              class="category-chip {{activeCategoryId === item.id ? 'active' : ''}}"
              data-id="{{item.id}}"
              data-filter-key="{{item.filterKey}}"
              bindtap="onCategoryTap"
            >
              {{item.name}}
            </view>
          </block>
        </view>
      </scroll-view>
    </view>

    <view class="product-grid">
      <block wx:for="{{filteredProductList}}" wx:key="id">
        <view class="product-card" data-id="{{item.id}}" bindtap="openProductCard">
          <view class="product-cover-wrap">
            <image class="product-cover" src="{{item.cover}}" mode="aspectFill" lazy-load />
          </view>

          <view class="product-body">
            <view class="product-topline">
              <text class="product-badge">调色课程</text>
              <text class="product-format" wx:if="{{item.format}}">{{item.format}}</text>
            </view>
            <view class="product-title">{{item.title}}</view>
            <view class="product-desc">{{item.description || item.accent}}</view>
            <view class="tag-row" wx:if="{{item.tags && item.tags.length}}">
              <text class="product-tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
            </view>

            <view class="price-row">
              <view class="price-meta">
                <view class="price-main">¥{{item.price}}</view>
                <view class="price-origin">¥{{item.originalPrice}}</view>
              </view>
              <view class="course-action">查看课程</view>
            </view>
          </view>
        </view>
      </block>
    </view>

    <view class="bottom-spacer"></view>
  </view>
</view>
