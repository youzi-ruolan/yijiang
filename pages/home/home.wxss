page {
  box-sizing: border-box;
  background: #f6f3ef;
  color: #111111;
  padding-bottom: calc(env(safe-area-inset-bottom) + 128rpx);
}

.home-page {
  min-height: 100vh;
  background:
    linear-gradient(180deg, #fffaf6 0, #f6f3ef 280rpx, #f6f3ef 100%);
}

.home-shell,
.home-skeleton {
  display: block;
  padding: 24rpx 24rpx 0;
}

.search-bar {
  margin-top: 8rpx;
  height: 84rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  border-radius: 42rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #c4c4c4;
  box-shadow: 0 8rpx 24rpx rgba(114, 88, 63, 0.06);
}

.search-text {
  flex: 1;
  font-size: 26rpx;
  color: #b8b1a9;
}

.hero-wrap {
  position: relative;
  margin-top: 26rpx;
  padding: 0 6rpx 18rpx;
}

.hero-swiper {
  height: 420rpx;
  border-radius: 34rpx;
  overflow: hidden;
  box-shadow: 0 22rpx 48rpx rgba(148, 102, 66, 0.12);
}

.hero-slide {
  position: relative;
  height: 420rpx;
  overflow: hidden;
  border-radius: 34rpx;
}

.hero-image {
  width: 100%;
  height: 100%;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.04) 0%, rgba(51, 31, 16, 0.12) 100%);
}

.hero-content {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 22rpx;
}

.hero-badge,
.hero-title,
.hero-subtitle,
.hero-description,
.hero-actions {
  display: none;
}

.hero-indicators {
  position: absolute;
  left: 38rpx;
  bottom: 34rpx;
  z-index: 2;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.hero-indicator {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.52);
  transition: all 0.2s ease;
}

.hero-indicator.active {
  width: 34rpx;
  border-radius: 999rpx;
  background: #ffffff;
}

.sticky-tabs {
  position: sticky;
  top: 0;
  z-index: 8;
  background: rgba(246, 243, 239, 0.96);
  padding: 12rpx 0 10rpx;
  backdrop-filter: blur(10rpx);
}

.category-scroll {
  margin-top: 12rpx;
  white-space: nowrap;
}

.category-track {
  display: inline-flex;
  gap: 16rpx;
  align-items: center;
}

.category-chip {
  position: relative;
  flex: 0 0 auto;
  padding: 16rpx 24rpx;
  color: #7c7064;
  font-size: 26rpx;
  font-weight: 500;
  line-height: 1;
  background: rgba(255, 255, 255, 0.84);
  border-radius: 999rpx;
  box-shadow: 0 8rpx 18rpx rgba(114, 88, 63, 0.05);
}

.category-chip.active {
  color: #ffffff;
  font-weight: 600;
  background: linear-gradient(135deg, #ff8574 0%, #ff5c51 100%);
  box-shadow: 0 14rpx 26rpx rgba(255, 92, 81, 0.2);
}

.category-chip.active::after {
  display: none;
}

.product-grid {
  margin-top: 24rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 24rpx 0;
}

.product-card {
  width: 342rpx;
  overflow: hidden;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 36rpx rgba(114, 88, 63, 0.08);
}

.product-cover-wrap {
  position: relative;
  height: 350rpx;
  padding: 18rpx;
  background: linear-gradient(180deg, #fbf8f4 0%, #f4efea 100%);
}

.product-cover {
  width: 100%;
  height: 100%;
  border-radius: 20rpx;
}

.product-body {
  padding: 20rpx 18rpx 20rpx;
}

.product-title {
  font-size: 28rpx;
  line-height: 1.45;
  font-weight: 600;
  color: #111111;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  min-height: 82rpx;
}

.price-row {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.price-meta {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
}

.price-main {
  color: #ff5c51;
  font-size: 32rpx;
  font-weight: 700;
}


.cart-mini-button {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #fff3f1;
}

.bottom-spacer {
  height: 56rpx;
}

.home-skeleton {
  padding-top: 24rpx;
}

.skeleton-block,
.skeleton-chip,
.skeleton-card {
  background: linear-gradient(90deg, #f2f2f2 25%, #e9e9e9 37%, #f2f2f2 63%);
  background-size: 400% 100%;
  animation: skeleton-shimmer 1.4s ease infinite;
  border-radius: 24rpx;
}

.skeleton-header {
  width: 360rpx;
  height: 54rpx;
}

.skeleton-search {
  margin-top: 24rpx;
  width: 100%;
  height: 84rpx;
}

.skeleton-banner {
  margin-top: 24rpx;
  width: 100%;
  height: 392rpx;
}

.skeleton-grid {
  display: flex;
  gap: 14rpx;
  flex-wrap: wrap;
  margin-top: 24rpx;
}

.skeleton-chip {
  width: 140rpx;
  height: 56rpx;
}

.skeleton-grid.cards {
  gap: 20rpx;
}

.skeleton-card {
  width: 342rpx;
  height: 520rpx;
}

@keyframes skeleton-shimmer {
  0% {
    background-position: 100% 0;
  }

  100% {
    background-position: 0 0;
  }
}
