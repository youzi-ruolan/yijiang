:host {
  background-color: #f5f5f5;
}
page view {
  box-sizing: border-box;
}
.person-info {
  padding-top: 20rpx;
}

.person-info__btn {
  width: 100%;
  border: 2rpx solid rgba(250, 85, 15, 0.24);
  border-radius: 48rpx;
  padding: 20rpx 0;
  display: flex;
  align-self: center;
  justify-content: center;
  color: #d5490c;
  font-size: 28rpx;
  font-weight: 500;
  background: rgba(250, 85, 15, 0.06);
}
.person-info__wrapper {
  width: 100%;
  padding: 0 32rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 20rpx);
  position: absolute;
  bottom: 0;
  left: 0;
}

.avatarUrl {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50% !important;
  overflow: hidden;
}

.avatar-choose-btn {
  padding: 0;
  margin: 0;
  border: 0;
  background: transparent;
  line-height: 1;
}

.avatar-choose-btn::after {
  border: 0;
}

.person-info .order-group__left {
  margin-right: 0;
}
.person-info .t-cell-class {
  height: 112rpx;
}
