<view class="name-edit">
  <t-input
    borderless
    model:value="{{nameValue}}"
    type="nickname"
    placeholder="请输入文字"
    label="昵称"
    clearable
    bind:clear="clearContent"
  />
  <view class="name-edit__input--desc"> 可直接填写或使用微信推荐昵称，最多15个字 </view>
  <view class="name-edit__wrapper">
    <t-button block shape="round" disabled="{{!nameValue}}" bind:tap="onSubmit">保存</t-button>
  </view>
</view>
<t-toast id="t-toast" />
