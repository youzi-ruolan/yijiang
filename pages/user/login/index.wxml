<view class="login-page">
  <view class="login-head">
    <view class="login-title">{{mode === 'login' ? '欢迎回来' : '创建账号'}}</view>
    <view class="login-subtitle">登录后可管理订单、收货地址与商品评价</view>
  </view>

  <view class="mode-switch">
    <view class="mode-item {{mode === 'login' ? 'active' : ''}}" data-mode="login" bindtap="switchMode">登录</view>
    <view class="mode-item {{mode === 'register' ? 'active' : ''}}" data-mode="register" bindtap="switchMode"
      >注册</view
    >
  </view>

  <view class="form-card">
    <t-input
      label="手机号"
      type="number"
      maxlength="11"
      value="{{phoneNumber}}"
      placeholder="请输入手机号"
      data-field="phoneNumber"
      bind:change="onInput"
    />
    <t-input
      wx:if="{{mode === 'register'}}"
      label="昵称"
      value="{{nickName}}"
      maxlength="15"
      placeholder="请输入昵称"
      data-field="nickName"
      bind:change="onInput"
    />
    <t-input
      label="密码"
      type="password"
      value="{{password}}"
      placeholder="至少 6 位"
      data-field="password"
      bind:change="onInput"
    />
    <t-input
      wx:if="{{mode === 'register'}}"
      label="确认密码"
      type="password"
      value="{{confirmPassword}}"
      placeholder="请再次输入密码"
      data-field="confirmPassword"
      bind:change="onInput"
    />
  </view>

  <view class="submit-wrap">
    <t-button block shape="round" loading="{{loading}}" bind:tap="submit">
      {{mode === 'login' ? '登录' : '注册并登录'}}
    </t-button>
  </view>
</view>
<t-toast id="t-toast" />
