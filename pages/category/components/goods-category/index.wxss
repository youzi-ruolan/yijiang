.goods-category {
  display: flex;
  height: 100%;
}

.custom-sidebar {
  height: 100%;
}

.goods-category__right {
  height: 100%;
  flex: auto;
  width: 0;
  position: relative;
  overflow: scroll;
  -webkit-overflow-scrolling: touch;
  background: transparent;
}

.flex {
  display: flex;
}

.goods-category-normal {
  margin: 22rpx 20rpx 0 18rpx;
}

.goods-category-normal-item-container {
  background-color: #fff;
  border-radius: 30rpx;
  padding: 18rpx 14rpx 10rpx;
  margin-top: 0;
  margin-bottom: 20rpx;
  display: flex;
  flex-wrap: wrap;
  box-shadow: 0 16rpx 36rpx rgba(114, 88, 63, 0.08);
}

.goods-category-normal-item-container-item {
  height: 212rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  width: 33.3%;
}

.goods-category-normal-item-container-item .image {
  width: 148rpx;
  height: 148rpx;
  border-radius: 22rpx;
  overflow: hidden;
  background: linear-gradient(180deg, #fbf8f4 0%, #f3ede7 100%);
}

.goods-category-normal-item-container-item-title {
  justify-content: center;
  font-size: 24rpx;
  color: #5f564f;
  margin-top: 14rpx;
  line-height: 1.4;
  text-align: center;
  padding: 0 10rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.goods-category .custom-sidebar {
  background-color: transparent;
}

.custom-sidebar {
  width: 188rpx;
  height: 100vh;
}

.custom-sidebar::-webkit-scrollbar {
  width: 0;
  height: 0;
  color: transparent;
}

.goods-category-normal-item-second-container {
  background-color: #fff;
  border-radius: 30rpx;
  margin-top: 0;
  margin-bottom: 20rpx;
  padding: 16rpx 10rpx 8rpx;
  display: grid;
  grid-template-columns: 33.33% 33.33% 33.33%;
  box-shadow: 0 16rpx 36rpx rgba(114, 88, 63, 0.08);
}

.goods-category-normal-item-second-container-item {
  height: 212rpx;
  text-align: center;
  margin-top: 0;
}

.goods-category-normal-item-second-container-item .image {
  width: 148rpx;
  height: 148rpx;
  border-radius: 22rpx;
  overflow: hidden;
  background: linear-gradient(180deg, #fbf8f4 0%, #f3ede7 100%);
}

.goods-category-normal-item-second-container-item-title {
  justify-content: center;
  font-size: 24rpx;
  color: #5f564f;
  margin-top: 14rpx;
  line-height: 1.4;
  padding: 0 10rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
