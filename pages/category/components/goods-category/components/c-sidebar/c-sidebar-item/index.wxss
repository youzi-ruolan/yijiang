.c-sidebar-item {
  display: flex;
  justify-content: center;
  text-align: center;
  background-color: transparent;
  color: #222427;
  padding: 8rpx 12rpx;
  margin: 8rpx 10rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

.c-sidebar-item.active {
  position: relative;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 26rpx;
  box-shadow: 0 12rpx 24rpx rgba(114, 88, 63, 0.08);
}

.c-sidebar-item.active::before {
  content: '';
  position: absolute;
  width: 8rpx;
  height: 38rpx;
  background-color: #ff6a5f;
  left: 14rpx;
  top: 50%;
  transform: translate(0, -50%);
  border-radius: 64rpx;
}

.c-sidebar-item__text {
  width: 100%;
  min-height: 40rpx;
  padding: 14rpx 18rpx 14rpx 28rpx;
  line-height: 1.4;
  text-align: center;
  font-size: 26rpx;
  font-weight: 500;
  color: #7c7064;
  box-sizing: border-box;
}

.c-sidebar-item.active .c-sidebar-item__text {
  background-color: transparent;
  border-radius: 36rpx;
  color: #ff5c51;
  font-weight: 600;
}

.text-overflow {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.top-right-radius {
  border-top-right-radius: 26rpx;
}

.bottom-right-radius {
  border-bottom-right-radius: 26rpx;
}

.c-sidebar-item-container {
  background-color: transparent;
}
