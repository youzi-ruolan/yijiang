.wrap {
  height: 100vh;
  overflow: hidden;
  padding: 16rpx 16rpx 0;
  box-sizing: border-box;
  background:
    linear-gradient(180deg, #fffaf6 0, #f6f3ef 220rpx, #f6f3ef 100%);
}

.goods-category-class {
  background-color: transparent !important;
  height: 100%;
  border-radius: 32rpx;
  overflow: hidden;
}

.goods-category-class .goods-category-normal-item-container-item {
  margin-top: 0;
}

page {
  min-height: 100vh;
  padding-bottom: 0;
  background: #f6f3ef;
}
