<view class="goods-detail-page">
  <view class="goods-head">
    <view class="detail-swiper-wrap">
      <swiper
        wx:if="{{details.images.length > 0}}"
        class="detail-swiper"
        current="{{current}}"
        autoplay="{{autoplay}}"
        duration="{{duration}}"
        interval="{{interval}}"
        circular
        bindchange="handleSwiperChange"
      >
        <block wx:for="{{details.images}}" wx:key="*this">
          <swiper-item>
            <view class="detail-swiper-item" data-index="{{index}}" bindtap="showCurImg">
              <image class="detail-swiper-image" src="{{item}}" mode="aspectFill" lazy-load show-menu-by-longpress />
            </view>
          </swiper-item>
        </block>
      </swiper>
      <view wx:if="{{details.images.length > 1}}" class="detail-swiper-indicator">
        {{current + 1}} / {{details.images.length}}
      </view>
    </view>
    <view class="goods-info">
      <view class="goods-number">
        <view class="goods-price">
          <price
            wr-class="class-goods-price"
            symbol-class="class-goods-symbol"
            price="{{minSalePrice}}"
            type="lighter"
          />
        </view>
        <view class="sold-num">已售{{soldNum}}</view>
      </view>
      <view class="goods-title">
        <view class="goods-name">{{details.title}}</view>
        <view class="goods-tag">
          <t-button open-type="share" t-class="shareBtn" variant="text">
            <view class="btn-icon">
              <t-icon name="share" size="40rpx" color="#000" />
              <view class="share-text">分享</view>
            </view>
          </t-button>
        </view>
      </view>
      <view class="goods-intro">{{intro}}</view>
      <view class="goods-tags" wx:if="{{details.spuTagList && details.spuTagList.length}}">
        <view class="goods-meta-tag" wx:for="{{details.spuTagList}}" wx:key="id">{{item.title}}</view>
      </view>
    </view>
    <view class="comments-wrap">
      <view class="comments-head" bindtap="navToCommentsListPage">
        <view class="comments-title-wrap">
          <view class="comments-title-label">商品评价</view>
          <view class="comments-title-count"> ({{ commentsStatistics.commentCount }}) </view>
        </view>
        <view class="comments-rate-wrap">
          <view class="comments-good-rate">{{commentsStatistics.goodRate}}% 好评</view>
          <t-icon name="chevron-right" size="40rpx" color="#BBBBBB" />
        </view>
      </view>
      <view class="comment-item-wrap" wx:for="{{ commentsList }}" wx:for-item="commentItem" wx:key="goodsSpu">
        <view class="comment-item-head">
          <t-image src="{{commentItem.userHeadUrl}}" t-class="comment-item-avatar" />
          <view class="comment-head-right">
            <view class="comment-username">{{commentItem.userName}}</view>
            <t-rate
              value="{{ commentItem.commentScore }}"
              count="{{5}}"
              size="12"
              gap="2"
              color="{{['#ffc51c', '#ddd']}}"
            />
          </view>
        </view>
        <view class="comment-item-content"> {{commentItem.commentContent}} </view>
      </view>
      <view wx:if="{{commentsStatistics.commentCount <= 0}}" class="comment-empty">暂无评价</view>
    </view>
  </view>
  <view class="desc-content">
    <view class="detail-section detail-section--card" wx:if="{{deliverables.length > 0 || usageNotice.length > 0}}">
      <view class="detail-section-head">
        <view class="detail-section-head__bar"></view>
        <view class="detail-section-head__title">课程说明</view>
      </view>
      <view class="detail-card-group">
        <view class="detail-card" wx:if="{{deliverables.length > 0}}">
          <view class="detail-card__title">交付内容</view>
          <view class="detail-card__item" wx:for="{{deliverables}}" wx:key="index">{{item}}</view>
        </view>
        <view class="detail-card" wx:if="{{usageNotice.length > 0}}">
          <view class="detail-card__title">使用说明</view>
          <view class="detail-card__item" wx:for="{{usageNotice}}" wx:key="index">{{item}}</view>
        </view>
      </view>
    </view>
    <view class="detail-section detail-section--media" wx:if="{{galleryMedia.length > 0}}">
      <view class="detail-section-head">
        <view class="detail-section-head__bar"></view>
        <view class="detail-section-head__title">详情图集</view>
      </view>
      <view class="detail-gallery-list">
        <block wx:for="{{galleryMedia}}" wx:key="url">
          <image
            wx:if="{{item.type === 'image'}}"
            class="detail-gallery-image"
            src="{{item.url}}"
            mode="widthFix"
            lazy-load
            show-menu-by-longpress
            data-url="{{item.url}}"
            bindtap="previewGalleryImage"
          />
          <view wx:else class="detail-video-wrap">
            <video
              class="detail-video"
              src="{{item.url}}"
              poster="{{item.cover}}"
              controls
              object-fit="cover"
              show-center-play-btn
              enable-play-gesture
            />
          </view>
        </block>
      </view>
    </view>
    <view class="detail-section detail-section--rich" wx:if="{{detailBlocks.length > 0}}">
      <view class="detail-section-head">
        <view class="detail-section-head__bar"></view>
        <view class="detail-section-head__title">课程详情</view>
      </view>
      <view class="detail-rich-content">
        <block wx:for="{{detailBlocks}}" wx:key="index">
          <rich-text wx:if="{{item.type === 'rich'}}" class="detail-rich-text" nodes="{{item.html}}" />
          <image
            wx:elif="{{item.type === 'image'}}"
            class="detail-rich-image"
            src="{{item.url}}"
            mode="widthFix"
            lazy-load
            show-menu-by-longpress
            data-url="{{item.url}}"
            bindtap="previewDetailImage"
          />
          <view wx:elif="{{item.type === 'video'}}" class="detail-video-wrap detail-video-wrap--rich">
            <video
              class="detail-video"
              src="{{item.url}}"
              poster="{{item.poster}}"
              controls
              object-fit="cover"
              show-center-play-btn
              enable-play-gesture
            />
          </view>
          <view
            wx:elif="{{item.type === 'external-video'}}"
            class="detail-external-video"
            bindtap="openExternalVideo"
            data-url="{{item.url}}"
          >
            <view class="detail-video-cover">
              <image
                wx:if="{{item.poster}}"
                class="detail-video-cover__poster"
                src="{{item.poster}}"
                mode="aspectFill"
              />
              <view wx:else class="detail-video-cover__fallback"></view>
              <view class="detail-video-play detail-video-play--overlay">
                <view class="detail-video-play__ring">
                  <view class="detail-video-play__icon"></view>
                </view>
              </view>
              <view class="detail-video-cover__mask"></view>
            </view>
            <view class="detail-external-video__body">
              <view class="detail-external-video__label">{{item.label || '外链视频'}}</view>
              <view class="detail-external-video__tip">点击复制链接，在浏览器中观看</view>
            </view>
          </view>
        </block>
      </view>
    </view>

    <view class="desc-content__title" wx:if="{{detailBlocks.length === 0 && galleryMedia.length === 0 && detailMedia.length > 0}}">
      <t-image t-class="img" src="{{recLeftImg}}" />
      <span class="desc-content__title--text">详情介绍</span>
      <t-image t-class="img" src="{{recRightImg}}" />
    </view>
    <view wx:if="{{detailBlocks.length === 0 && galleryMedia.length === 0 && detailMedia.length > 0}}" wx:for="{{detailMedia}}" wx:key="index">
      <t-image wx:if="{{item.type == 'image'}}" t-class="desc-content__img" src="{{item.url}}" mode="widthFix" />
      <view wx:else class="detail-video-wrap detail-video-wrap--legacy">
        <video
          class="detail-video"
          src="{{item.url}}"
          poster="{{item.cover}}"
          controls
          object-fit="cover"
          show-center-play-btn
          enable-play-gesture
        />
      </view>
    </view>
  </view>
  <view class="detail-bottom-spacer" aria-hidden="true"></view>
  <view class="goods-bottom-operation">
    <view wx:if="{{cartFlyVisible}}" class="cart-fly-dot"></view>
    <buy-bar
      jumpArray="{{jumpArray}}"
      soldout="{{soldout}}"
      isStock="{{isStock}}"
      shopCartNum="{{cartNum}}"
      buttonType="{{buttonType}}"
      bind:toAddCart="toAddCart"
      bind:toNav="toNav"
      bind:toBuyNow="buyItNow"
      class="goods-details-card"
    />
  </view>
  <goods-specs-popup
    id="goodsSpecsPopup"
    show="{{isSpuSelectPopupShow}}"
    title="{{details.title || ''}}"
    src="{{specImg ? specImg : primaryImage}}"
    specList="{{details.specList || []}}"
    skuList="{{skuArray}}"
    limitBuyInfo="{{limitBuyInfo}}"
    bind:closeSpecsPopup="handlePopupHide"
    bind:change="chooseSpecItem"
    bind:changeNum="changeNum"
    bind:addCart="addCart"
    bind:buyNow="gotoBuy"
    bind:specsConfirm="specsConfirm"
    isStock="{{isStock}}"
    outOperateStatus="{{outOperateStatus}}"
  >
    <view slot="goods-price">
      <view class="popup-sku__price">
        <price
          wx:if="{{!isAllSelectedSku || (!promotionSubCode && isAllSelectedSku)}}"
          price="{{selectSkuSellsPrice ? selectSkuSellsPrice : minSalePrice }}"
          wr-class="popup-sku__price-num"
          symbol-class="popup-sku__price-symbol"
        />
      </view>
    </view>
  </goods-specs-popup>
</view>
<t-toast id="t-toast" />
