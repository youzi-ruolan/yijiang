@import '../../../style/global.wxss';
page {
  width: 100vw;
  background: #f7f7f7;
  padding-bottom: calc(env(safe-area-inset-bottom) + 200rpx);
}

.goods-detail-page .detail-swiper-wrap {
  position: relative;
}

.goods-detail-page .detail-swiper {
  height: 750rpx;
  background: #000;
}

.goods-detail-page .detail-swiper-item {
  width: 100%;
  height: 750rpx;
  overflow: hidden;
  background: #000;
}

.goods-detail-page .detail-swiper-image {
  width: 100%;
  height: 100%;
  display: block;
}

.goods-detail-page .detail-swiper-indicator {
  position: absolute;
  right: 24rpx;
  top: 680rpx;
  z-index: 2;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.38);
  color: #fff;
  font-size: 22rpx;
}

.goods-detail-page .goods-info {
  margin: 0 auto;
  padding: 26rpx 0 28rpx 30rpx;
  background-color: #fff;
}

.goods-detail-page .swipe-img {
  width: 100%;
  height: 750rpx;
}

.goods-detail-page .goods-info .goods-price {
  display: flex;
  align-items: baseline;
}

.goods-detail-page .goods-info .goods-price-up {
  color: #fa4126;
  font-size: 28rpx;
  position: relative;
  bottom: 4rpx;
  left: 8rpx;
}

.goods-detail-page .goods-info .goods-price .class-goods-price {
  font-size: 64rpx;
  color: #fa4126;
  font-weight: bold;
  font-family: DIN Alternate;
}

.goods-detail-page .goods-info .goods-price .class-goods-symbol {
  font-size: 36rpx;
  color: #fa4126;
}

.goods-detail-page .goods-info .goods-price .class-goods-del {
  position: relative;
  font-weight: normal;
  left: 16rpx;
  bottom: 2rpx;
  color: #999999;
  font-size: 32rpx;
}

.goods-detail-page .goods-info .goods-number {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.goods-detail-page .goods-info .goods-number .sold-num {
  font-size: 24rpx;
  color: #999999;
  display: flex;
  align-items: flex-end;
  margin-right: 32rpx;
}

.goods-detail-page .goods-info .goods-activity {
  display: flex;
  margin-top: 16rpx;
  justify-content: space-between;
}

.goods-detail-page .goods-info .goods-activity .tags-container {
  display: flex;
}

.goods-detail-page .goods-info .goods-activity .tags-container .goods-activity-tag {
  background: #ffece9;
  color: #fa4126;
  font-size: 24rpx;
  margin-right: 16rpx;
  padding: 4rpx 8rpx;
  border-radius: 4rpx;
}

.goods-detail-page .goods-info .goods-activity .activity-show {
  display: flex;
  justify-content: center;
  align-items: center;
  color: #fa4126;
  font-size: 24rpx;
  padding-right: 32rpx;
}

.goods-detail-page .goods-info .goods-activity .activity-show-text {
  line-height: 42rpx;
}

.goods-detail-page .goods-info .goods-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}

.goods-detail-page .goods-info .goods-title .goods-name {
  width: 600rpx;
  font-weight: 500;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  font-size: 32rpx;
  word-break: break-all;
  color: #333333;
}

.goods-detail-page .goods-info .goods-title .goods-tag {
  width: 104rpx;
  margin-left: 26rpx;
}

.goods-detail-page .goods-info .goods-title .goods-tag .shareBtn {
  border-radius: 200rpx 0px 0px 200rpx;
  width: 100rpx;
  height: 96rpx;
  border: none;
  padding-right: 36rpx !important;
}

.goods-detail-page .goods-info .goods-title .goods-tag .shareBtn::after {
  border: none;
}

.goods-detail-page .goods-info .goods-title .goods-tag .btn-icon {
  font-size: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  color: #999;
}

.goods-detail-page .goods-info .goods-title .goods-tag .btn-icon .share-text {
  padding-top: 8rpx;
  font-size: 20rpx;
  line-height: 24rpx;
}

.goods-detail-page .goods-info .goods-intro {
  font-size: 26rpx;
  color: #888;
  line-height: 36rpx;
  word-break: break-all;
  padding-right: 30rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  white-space: normal;
  overflow: hidden;
}

.goods-detail-page .goods-highlights {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 20rpx;
  padding: 20rpx 22rpx;
  margin-right: 30rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fff7f1 0%, #fffdfb 100%);
}

.goods-detail-page .goods-highlights .goods-highlight {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
  color: #6b5b4d;
  line-height: 1.6;
}

.goods-detail-page .goods-info .goods-meta {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-top: 18rpx;
  padding-right: 30rpx;
}

.goods-detail-page .goods-info .goods-meta .goods-meta-item {
  font-size: 24rpx;
  color: #666;
  line-height: 34rpx;
}

.goods-detail-page .goods-info .goods-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
  padding-right: 30rpx;
}

.goods-detail-page .goods-info .goods-meta-tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #fff1ee;
  color: #fa4126;
  font-size: 22rpx;
}

.goods-detail-page .goods-facts {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
  padding-right: 30rpx;
}

.goods-detail-page .goods-fact {
  padding: 10rpx 18rpx;
  border-radius: 16rpx;
  background: #f6f1eb;
  color: #7b6859;
  font-size: 22rpx;
  line-height: 1.4;
}

.spu-select {
  height: 80rpx;
  background-color: #fff;
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  padding: 30rpx;
  font-size: 28rpx;
}

.spu-select .label {
  margin-right: 30rpx;
  text-align: center;
  flex-shrink: 0;
  color: #999999;
  font-weight: normal;
}

.spu-select .content {
  display: flex;
  flex: 1;
  justify-content: space-between;
  align-items: center;
}

.spu-select .content .tintColor {
  color: #aaa;
}

.goods-detail-page .desc-content {
  margin-top: 20rpx;
  background-color: #fff;
  padding-bottom: 32rpx;
}

.goods-detail-page .detail-block {
  margin: 0 24rpx;
  padding: 30rpx 8rpx 6rpx;
  border-bottom: 1rpx solid #f1e8e1;
}

.goods-detail-page .detail-block--card {
  padding-bottom: 0;
  border-bottom: none;
}

.goods-detail-page .detail-card-group {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.goods-detail-page .detail-card {
  padding: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fffdfb 0%, #f8f2ec 100%);
}

.goods-detail-page .detail-card__title {
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 600;
  color: #2f241d;
}

.goods-detail-page .detail-card__item {
  position: relative;
  padding-left: 18rpx;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6a5d51;
}

.goods-detail-page .detail-card__item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 16rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #ff6f61;
}

.goods-detail-page .detail-block--plain {
  padding-top: 26rpx;
}

.goods-detail-page .detail-block__title {
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 600;
  color: #222;
}

.goods-detail-page .detail-block__list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.goods-detail-page .detail-block__item {
  color: #666;
  font-size: 26rpx;
  line-height: 42rpx;
  word-break: break-all;
}

.goods-detail-page .detail-block__item--dot {
  position: relative;
  padding-left: 20rpx;
}

.goods-detail-page .detail-block__item--dot::before {
  content: '';
  position: absolute;
  left: 0;
  top: 16rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #fa4126;
}

.goods-detail-page .detail-rich-content {
  padding: 0 8rpx;
  overflow: hidden;
}

.goods-detail-page .detail-rich-text {
  display: block;
  width: 100%;
  color: #333;
  font-size: 28rpx;
  line-height: 1.8;
  word-break: break-word;
  overflow: hidden;
}

.goods-detail-page .detail-rich-image {
  width: 100%;
  display: block;
  margin: 16rpx 0;
  border-radius: 12rpx;
}

.goods-detail-page .detail-rich-video {
  width: 100%;
  margin: 16rpx 0;
  border-radius: 12rpx;
  background: #000;
}

.goods-detail-page .detail-external-video {
  margin: 16rpx 0;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f7f2ec;
  border: 1px solid #eadfd4;
}

.goods-detail-page .detail-external-video__poster {
  width: 100%;
  height: 320rpx;
  display: block;
}

.goods-detail-page .detail-external-video__body {
  padding: 20rpx 24rpx 24rpx;
}

.goods-detail-page .detail-external-video__label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.goods-detail-page .detail-external-video__tip {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #8d7b6d;
}

.goods-detail-page .detail-gallery-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.goods-detail-page .detail-gallery-image {
  width: 100%;
  display: block;
  border-radius: 12rpx;
}

.goods-detail-page .detail-gallery-video {
  width: 100%;
  border-radius: 12rpx;
  background: #000;
}

.goods-detail-page .desc-content__title {
  font-size: 28rpx;
  line-height: 36rpx;
  text-align: center;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 30rpx 20rpx;
}

.goods-detail-page .desc-content__title .img {
  width: 206rpx;
  height: 10rpx;
}

.goods-detail-page .desc-content__title--text {
  font-size: 26rpx;
  margin: 0 32rpx;
  font-weight: 600;
}

.goods-detail-page .desc-content__img {
  width: 100%;
  height: auto;
}

.goods-detail-page .desc-content__video {
  display: block;
  width: calc(100% - 48rpx);
  height: 420rpx;
  margin: 0 24rpx 24rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: #111;
}

.goods-bottom-operation {
  position: fixed;
  left: 0;
  bottom: 0;
  width: 100%;
  background-color: #fff;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 10;
}

.cart-fly-dot {
  position: absolute;
  left: 374rpx;
  bottom: calc(70rpx + env(safe-area-inset-bottom));
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  background: #fa4126;
  box-shadow: 0 8rpx 18rpx rgba(250, 65, 38, 0.36);
  animation: cart-fly 720ms cubic-bezier(0.22, 0.76, 0.28, 1) forwards;
  pointer-events: none;
  z-index: 12;
}

@keyframes cart-fly {
  0% {
    opacity: 0;
    transform: translate(0, 0) scale(0.7);
  }
  12% {
    opacity: 1;
  }
  55% {
    opacity: 1;
    transform: translate(-96rpx, -144rpx) scale(1);
  }
  100% {
    opacity: 0;
    transform: translate(-188rpx, -6rpx) scale(0.42);
  }
}

.popup-sku-header .popup-sku-header__goods-info .popup-sku__price {
  display: flex;
  align-items: baseline;
  color: #fa4126;
  margin-top: 48rpx;
}

.popup-sku-header .popup-sku-header__goods-info .popup-sku__price .popup-sku__price-num {
  font-size: 64rpx;
  color: #fa4126;
  font-weight: bold;
  font-family: DIN Alternate;
}

.popup-sku-header .popup-sku-header__goods-info .popup-sku__price .popup-sku__price-del {
  position: relative;
  font-weight: normal;
  left: 12rpx;
  bottom: 2rpx;
  color: #999999;
  font-size: 32rpx;
}

.popup-sku-header .popup-sku-header__goods-info .popup-sku__price .popup-sku__price-symbol {
  font-size: 36rpx;
  color: #fa4126;
}

.popup-sku-header .popup-sku-header__goods-info .popup-sku__price .popup-sku__price-max-num {
  font-size: 48rpx;
}

.goods-detail-page .goods-head {
  position: relative;
  --td-swiper-radius: 0;
}

.t-toast__content {
  z-index: 12000 !important;
}

.comments-wrap {
  margin-top: 20rpx;
  padding: 32rpx;
  background-color: #fff;
}

.comments-wrap .comments-head {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.comments-wrap .comments-head .comments-title-wrap {
  display: flex;
}

.comments-title-label,
.comments-title-count {
  color: #333333;
  font-size: 32rpx;
  font-weight: 500;
  line-height: 48rpx;
}

.comments-rate-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 24rpx;
}

.comments-rate-wrap .comments-good-rate {
  color: #999999;
  font-size: 26rpx;
  font-weight: 400;
  font-style: normal;
  line-height: 36rpx;
}

.comment-item-wrap .comment-item-head {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-top: 32rpx;
}

.comment-item-wrap .comment-item-head .comment-item-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 64rpx;
}

.comment-item-wrap .comment-item-head .comment-head-right {
  margin-left: 24rpx;
}

.comment-head-right .comment-username {
  font-size: 26rpx;
  color: #333333;
  line-height: 36rpx;
  font-weight: 400;
}

.comment-item-wrap .comment-item-content {
  margin-top: 20rpx;
  color: #333333;
  line-height: 40rpx;
  font-size: 28rpx;
  font-weight: 400;
}

.comment-empty {
  padding: 36rpx 0 8rpx;
  color: #999999;
  font-size: 26rpx;
  line-height: 36rpx;
  text-align: center;
}
