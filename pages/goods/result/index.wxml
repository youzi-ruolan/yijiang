<view class="result-container">
  <t-search
    t-class="t-search"
    t-class-input-container="t-class__input-container"
    t-class-left="t-search__left-icon"
    t-class-input="t-search__input"
    value="{{keywords}}"
    leftIcon=""
    placeholder="搜索商品"
    bind:change="onInputChange"
    bind:submit="handleSubmit"
  >
    <t-icon slot="left-icon" prefix="wr" name="search" size="40rpx" color="#bbb" />
  </t-search>
  <view class="result-meta" wx:if="{{keywords}}">
    <text class="result-meta__text">共 {{totalCount}} 个结果</text>
    <text class="result-meta__clear" bind:tap="clearKeywords">清空</text>
  </view>
  <view class="result-meta result-meta--recommend" wx:if="{{isRecommendMode && goodsList.length}}">
    <text class="result-meta__title">推荐商品</text>
    <text class="result-meta__text">搜索为空时为你推荐</text>
  </view>
  <view class="empty-wrap" wx:if="{{goodsList.length === 0 && hasLoaded}}">
    <t-empty t-class="empty-tips" size="240rpx" description="{{isRecommendMode ? '暂无推荐商品' : '暂无相关商品'}}" />
  </view>
  <view class="category-goods-list" wx:if="{{goodsList.length}}">
    <view class="product-grid">
      <view
        class="product-card"
        wx:for="{{goodsList}}"
        wx:key="spuId"
        data-id="{{item.spuId}}"
        bindtap="openProductCard"
      >
        <view class="product-cover-wrap">
          <image class="product-cover" src="{{item.cover}}" mode="aspectFill" lazy-load />
        </view>

        <view class="product-body">
          <view class="product-topline">
            <text class="product-badge">调色课程</text>
            <text class="product-format" wx:if="{{item.format}}">{{item.format}}</text>
          </view>
          <view class="product-title">{{item.title}}</view>
          <view class="product-desc">{{item.displayDescription}}</view>
          <view class="tag-row" wx:if="{{item.tags && item.tags.length}}">
            <view class="product-tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</view>
          </view>

          <view class="price-row">
            <view class="price-meta">
              <view class="price-main">¥{{item.price}}</view>
              <view class="price-origin">¥{{item.originalPrice}}</view>
            </view>
            <view class="course-action">查看课程</view>
          </view>
        </view>
      </view>
    </view>
  </view>
  <load-more wx:if="{{goodsList.length > 0}}" status="{{loadMoreStatus}}" no-more-text="没有更多了" />
</view>
<t-toast id="t-toast" />
