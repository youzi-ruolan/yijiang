.search-page {
  box-sizing: border-box;
  width: 100vw;
  height: 100vh;
  padding: 24rpx 28rpx 0;
  background: #f8f6f3;
}

.search-page .t-class__input-container {
  height: 74rpx !important;
  border-radius: 22rpx !important;
  background: #ffffff !important;
  box-shadow: none;
}

.search-page .t-search__input {
  font-size: 28rpx !important;
  color: #333 !important;
}

.search-page .search-wrap {
  margin-top: 26rpx;
}

.search-page .history-wrap {
  margin-bottom: 24rpx;
  padding: 24rpx 26rpx;
  border-radius: 24rpx;
  background: #ffffff;
}

.search-page .popular-wrap {
  padding: 24rpx 26rpx;
  border-radius: 24rpx;
  background: #ffffff;
}

.search-page .search-header {
  display: flex;
  flex-flow: row nowrap;
  justify-content: space-between;
  align-items: center;
}

.search-page .search-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #222;
  line-height: 40rpx;
}

.search-page .search-clear {
  font-size: 24rpx;
  line-height: 32rpx;
  color: #fa6a3b;
}

.search-page .search-content {
  overflow: hidden;
  display: flex;
  flex-flow: row wrap;
  justify-content: flex-start;
  align-items: flex-start;
  margin-top: 18rpx;
}

.search-page .search-item {
  color: #38322d;
  font-size: 24rpx;
  line-height: 32rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  background: #f4efe8;
  border-radius: 999rpx;
  padding: 12rpx 22rpx;
}

.search-page .hover-history-item {
  position: relative;
  top: 3rpx;
  left: 3rpx;
  box-shadow: 0px 0px 8px rgba(0, 0, 0, 0.1) inset;
}

.search-page .search-empty {
  width: 100%;
  padding: 10rpx 0 2rpx;
  font-size: 24rpx;
  color: #a1968a;
  line-height: 1.5;
}

.add-notes__confirm {
  color: #fa4126 !important;
}
