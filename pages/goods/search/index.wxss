.search-page {
  box-sizing: border-box;
  width: 100vw;
  height: 100vh;
  padding: 24rpx 30rpx 0;
  background: linear-gradient(180deg, #fffaf6 0%, #f5f1ec 100%);
}

.search-page .search-hero {
  padding: 18rpx 6rpx 22rpx;
}

.search-page .search-hero__eyebrow {
  font-size: 22rpx;
  color: #c08968;
  line-height: 1;
  margin-bottom: 14rpx;
}

.search-page .search-hero__title {
  font-size: 38rpx;
  line-height: 1.35;
  font-weight: 600;
  color: #2f241d;
}

.search-page .search-hero__desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #7d6d60;
}

.search-page .t-class__input-container {
  height: 76rpx !important;
  border-radius: 38rpx !important;
  background: rgba(255, 255, 255, 0.96) !important;
  box-shadow: 0 14rpx 34rpx rgba(114, 88, 63, 0.08);
}

.search-page .t-search__input {
  font-size: 28rpx !important;
  color: #333 !important;
}

.search-page .search-wrap {
  margin-top: 34rpx;
}

.search-page .history-wrap {
  margin-bottom: 34rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 14rpx 34rpx rgba(114, 88, 63, 0.06);
}

.search-page .popular-wrap {
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 14rpx 34rpx rgba(114, 88, 63, 0.06);
}

.search-page .search-header {
  display: flex;
  flex-flow: row nowrap;
  justify-content: space-between;
  align-items: center;
}

.search-page .search-title {
  font-size: 30rpx;
  font-family: PingFangSC-Semibold, PingFang SC;
  font-weight: 600;
  color: rgba(51, 51, 51, 1);
  line-height: 42rpx;
}

.search-page .search-clear {
  font-size: 24rpx;
  font-family: PingFang SC;
  line-height: 32rpx;
  color: #ff6f61;
  font-weight: normal;
}

.search-page .search-content {
  overflow: hidden;
  display: flex;
  flex-flow: row wrap;
  justify-content: flex-start;
  align-items: flex-start;
  margin-top: 24rpx;
}

.search-page .search-item {
  color: #4b4038;
  font-size: 24rpx;
  line-height: 32rpx;
  font-weight: normal;
  margin-right: 18rpx;
  margin-bottom: 18rpx;
  background: linear-gradient(180deg, #fff7f0 0%, #f7efe8 100%);
  border-radius: 38rpx;
  padding: 14rpx 24rpx;
}

.search-page .hover-history-item {
  position: relative;
  top: 3rpx;
  left: 3rpx;
  box-shadow: 0px 0px 8px rgba(0, 0, 0, 0.1) inset;
}

.search-page .search-empty {
  width: 100%;
  padding: 18rpx 0 8rpx;
  font-size: 24rpx;
  color: #9b8a7d;
  line-height: 1.7;
}

.add-notes__confirm {
  color: #fa4126 !important;
}
