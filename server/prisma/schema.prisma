generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id          String   @id @default(cuid())
  username    String   @unique
  password    String
  displayName String
  role        String   @default("个人管理员")
  avatar      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AppSetting {
  id                String   @id @default("default")
  appName           String
  appSlogan         String
  headlineTitle     String
  headlineSubtitle  String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Category {
  id        String   @id
  name      String
  filterKey String
  target    String
  sort      Int      @default(0)
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([target, sort])
}

model Product {
  id            String   @id
  title         String
  description   String   @db.Text
  price         Int
  sales         Int      @default(0)
  cover         String
  tags          Json
  gallery       Json
  detailContent Json
  deliverables  Json
  usageNotice   Json
  category      String
  isNew         Boolean  @default(false)
  isHot         Boolean  @default(false)
  sort          Int      @default(0)
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([category, sort])
  @@index([status, sort])
}

model Banner {
  id          String   @id
  title       String
  subtitle    String
  description String?  @db.Text
  image       String
  buttonText  String?
  badge       String?
  sort        Int      @default(0)
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Inspiration {
  id        String   @id
  title     String
  subtitle  String
  badge     String?
  cover     String
  sort      Int      @default(0)
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Article {
  id          String   @id
  title       String
  cover       String
  views       Int      @default(0)
  author      String
  publishTime String
  sort        Int      @default(0)
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id          String   @id
  userId      String?
  customer    String
  amount      Int
  status      String
  items       Int
  itemsDetail Json?
  orderCreatedAt String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model ProductComment {
  id              String   @id @default(cuid())
  orderNo         String
  spuId           String
  skuId           String
  userId          String
  userName        String
  userHeadUrl     String?
  isAnonymity     Boolean  @default(false)
  commentContent  String   @db.Text
  commentResources Json
  commentScore    Int
  commentLevel    Int
  serviceScore    Int      @default(5)
  conveyScore     Int      @default(5)
  goodsDetailInfo String?
  sellerReply     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([orderNo, skuId, userId])
  @@index([spuId, createdAt])
  @@index([userId, createdAt])
  @@index([commentLevel, createdAt])
}

model MiniProgramUser {
  id          String   @id @default(cuid())
  openid      String   @unique
  unionId     String?
  nickName    String
  avatarUrl   String?
  gender      Int      @default(0)
  phoneNumber String?
  addresses   UserAddress[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UserAddress {
  id            String          @id @default(cuid())
  userId        String
  user          MiniProgramUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  phone         String
  countryName   String          @default("中国")
  countryCode   String          @default("chn")
  provinceName  String
  provinceCode  String
  cityName      String
  cityCode      String
  districtName  String
  districtCode  String
  detailAddress String
  addressTag    String?
  latitude      Float?
  longitude     Float?
  isDefault     Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([userId, isDefault, createdAt])
  @@index([userId, createdAt])
}
